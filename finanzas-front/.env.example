# URL base de la API. En desarrollo se deja vacío y se usa el proxy de Vite (/api -> :8080).
# En producción, apunta al backend, p.ej: VITE_API_BASE_URL=https://api.tudominio.com
VITE_API_BASE_URL=

# Destino del proxy de Vite en desarrollo (opcional, por defecto http://localhost:8080)
VITE_API_TARGET=http://localhost:8080
